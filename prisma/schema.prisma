generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ════════════════════════════════════════════════════════════════
//  AUTH  (Better Auth, no admin plugin, no verification table,
//         no emailVerified — stripped at Prisma extension layer)
// ════════════════════════════════════════════════════════════════

enum Role {
  super_admin
  admin
}

// TS source uses 'full-time' / 'part-time' (hyphenated). Prisma
// enum identifiers disallow hyphens, so we use underscores here;
// seed + admin layer maps `'full-time'` ↔ `full_time`.
enum FacultyType {
  leadership
  full_time
  part_time
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String

  role        Role      @default(admin)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions    Session[]
  accounts    Account[]

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id         String   @id @default(cuid())
  userId     String
  providerId String
  accountId  String
  password   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

// ════════════════════════════════════════════════════════════════
//  CONTENT — SINGLETONS
// ════════════════════════════════════════════════════════════════

model DepartmentIdentity {
  id                 String   @id @default("singleton")
  name               String
  shortCode          String
  facultyName        String
  primaryColor       String
  accentColor        String
  buttonColor        String
  logoUrl            String
  logoPublicId       String?
  breadcrumbLabel    String
  heroImage1Url      String
  heroImage1PublicId String?
  heroImage1Alt      String?
  heroImage2Url      String
  heroImage2PublicId String?
  heroImage2Alt      String?
  heroImage3Url      String
  heroImage3PublicId String?
  heroImage3Alt      String?
  updatedAt          DateTime @updatedAt

  @@map("department_identity")
}

model UniversityIdentity {
  id            String   @id @default("singleton")
  name          String
  address       String   @db.Text
  phones        String[]
  emails        String[]
  facebookUrl   String?
  instagramUrl  String?
  youtubeUrl    String?
  linkedinUrl   String?
  xUrl          String?
  tiktokUrl     String?
  whatsappUrl   String?
  threadsUrl    String?
  erpUrl        String?
  applyUrl      String?
  libraryUrl    String?
  iqacUrl       String?
  careerUrl     String?
  noticeUrl     String?
  copyrightText String
  mapEmbedUrl   String?  @db.Text
  logoUrl       String
  logoPublicId  String?
  updatedAt     DateTime @updatedAt

  @@map("university_identity")
}

// ════════════════════════════════════════════════════════════════
//  CONTENT — LISTS
// ════════════════════════════════════════════════════════════════

model Program {
  id              String   @id @default(cuid())
  programName     String
  degreeCode      String   @unique
  duration        String
  description     String   @db.Text
  displayOrder    Int

  imageUrl        String?
  imagePublicId   String?
  specializations String[]
  cta             String?
  ctaHref         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([displayOrder])
  @@map("program")
}

model ResearchArea {
  id           String   @id @default(cuid())
  iconName     String?
  iconPublicId String?
  iconUrl      String?
  areaName     String
  description  String?  @db.Text
  displayOrder Int

  // Featured slot — exactly one row should have isFeatured=true.
  // Renders into the right-hand card on MajorResearchSection.
  // featuredHeading is optional override for the card's <h3>; null →
  // renderer falls back to areaName (keeps grid + featured visually
  // in sync unless an editor intentionally wants a richer title).
  isFeatured              Boolean @default(false)
  featuredHeading         String?
  featuredImageUrl        String?
  featuredImagePublicId   String?
  featuredDescription     String? @db.Text
  featuredCtaHref         String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@index([isFeatured])
  @@map("research_area")
}

// Faculty — Phase 2. Drives /faculty-member (list + [slug] detail)
// and the Dean's-message / Head's-message about pages via
// nullable message-extras columns on the same row.
model Faculty {
  id              String      @id @default(cuid())
  slug            String      @unique
  name            String
  designation     String
  secondaryTitle  String?
  badge           String?
  type            FacultyType
  displayOrder    Int

  // Photo (Cloudinary-paired, same convention as Program.imageUrl)
  photoUrl        String?
  photoPublicId   String?

  // Contact (all optional)
  email           String?
  phone           String?
  suId            String?

  // Variable-shape label/value list — `{label, value}[]`
  personalInfo    Json?

  // 8 detail sections — each can be:
  //   string | string[] | { heading: string; items: string[] }[]
  // Json is the only realistic storage for that union.
  academicQualification  Json?
  trainingExperience     Json?
  teachingArea           Json?
  publications           Json?
  research               Json?
  awards                 Json?
  membership             Json?
  previousEmployment     Json?

  // Dean / Head extras — flat nullable columns; only the 0–1 row(s)
  // flagged isDean / isHead populate these.
  isDean                    Boolean   @default(false)
  isHead                    Boolean   @default(false)
  messageOverline           String?
  messageHeading            String?
  messageParagraphs         String[]
  messagePhotoUrl           String?
  messagePhotoPublicId      String?
  messageTitleLine1         String?
  messageTitleLine2         String?
  messageHeroImageUrl       String?
  messageHeroImagePublicId  String?
  messageHeroImagePosition  String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([type, displayOrder])
  @@index([isDean])
  @@index([isHead])
  @@map("faculty")
}

// ════════════════════════════════════════════════════════════════
//  CHROME — NAVBAR + FOOTER STRUCTURE
//  Phase 3. Drives navbar (top bar, quick-access grid, main nav
//  groups + items) and footer (4 link columns). Everything that
//  was a hardcoded array in Navbar.tsx / Footer.tsx now lives here.
// ════════════════════════════════════════════════════════════════

model TopLink {
  // The thin top-bar row above the main navbar (Virtual Tour, IQAC,
  // Career, Archive, Contact). Hidden on mobile; collapses on scroll.
  id           String   @id @default(cuid())
  name         String
  href         String?  // null when isDisabled (e.g. "Virtual Tour", "Archive" have no destination yet)
  isExternal   Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("top_link")
}

model QuickAccessItem {
  // The 3-col grid in scrolled-navbar's right dropdown + mobile
  // drawer "Services" section. Single source of truth — both
  // surfaces render from this list.
  id           String   @id @default(cuid())
  name         String
  href         String?
  iconName     String   // Lucide icon name (BookOpen, GraduationCap, …)
  isExternal   Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("quick_access_item")
}

model MainNavGroup {
  // Each entry on the main nav bar (About, Faculty Member, Admission,
  // Student Society, Contact). `hasDropdown=false` → plain link
  // (href required, items empty). `hasDropdown=true` → dropdown
  // panel (href ignored, title + items drive the panel).
  id           String        @id @default(cuid())
  name         String
  href         String?
  hasDropdown  Boolean       @default(false)
  title        String?       // dropdown header text (usually same as name)
  displayOrder Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  items        MainNavItem[]

  @@index([displayOrder])
  @@map("main_nav_group")
}

model MainNavItem {
  id           String       @id @default(cuid())
  groupId      String
  name         String
  href         String
  isExternal   Boolean      @default(false)
  isDisabled   Boolean      @default(false)
  displayOrder Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  group        MainNavGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, displayOrder])
  @@map("main_nav_item")
}

model FooterUsefulLink {
  id           String   @id @default(cuid())
  name         String
  href         String?
  isExternal   Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("footer_useful_link")
}

model FooterGetInTouchLink {
  id           String   @id @default(cuid())
  name         String
  href         String?
  isExternal   Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("footer_get_in_touch_link")
}

model FooterQuickLink {
  id           String   @id @default(cuid())
  name         String
  href         String?
  isExternal   Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("footer_quick_link")
}

model FooterLegalLink {
  // Bottom-bar row (Privacy Statement, Terms of Use, Sitemap).
  // Flagged Phase 2/3 candidate in CP1.2 trade-offs; folded into
  // the Phase 3 full chrome sweep.
  id           String   @id @default(cuid())
  name         String
  href         String?
  isExternal   Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@map("footer_legal_link")
}

// ════════════════════════════════════════════════════════════════
//  ABOUT PAGES  (Phase 4)
//    Three singleton models — one per editable About page.
//    Lab pages (/about/lab-facility, /about/laboratory-facility)
//    are multi-row and deferred to Phase 5 in their entirety
//    (landing singletons + Lab list tables together).
// ════════════════════════════════════════════════════════════════

model AboutOverview {
  id                String   @id @default("singleton")
  // Hero (PageShell)
  heroTitle         String
  heroSubtitle      String?
  heroOverline      String?
  heroImageUrl      String
  heroImagePublicId String?
  heroImagePosition String?
  // Body — variable-length list of paragraph bodies (HTML allowed)
  paragraphs        String[]
  updatedAt         DateTime @updatedAt

  @@map("about_overview")
}

model AboutMissionVision {
  id                String   @id @default("singleton")
  // Hero
  heroTitle         String
  heroOverline      String?
  heroImageUrl      String
  heroImagePublicId String?
  heroImagePosition String?
  // Mission card
  missionOverline   String?
  missionHeading    String
  missionBody       String   @db.Text
  // Vision card
  visionOverline    String?
  visionHeading     String
  visionBody        String   @db.Text
  updatedAt         DateTime @updatedAt

  @@map("about_mission_vision")
}

model AboutMechaClub {
  id                       String   @id @default("singleton")
  // Hero
  heroTitle                String
  heroOverline             String?
  heroImageUrl             String
  heroImagePublicId        String?
  heroImagePosition        String?
  // Intro section
  introOverline            String?
  // introHeading allows inline HTML (e.g. <span class="text-gradient">)
  // — rendered via dangerouslySetInnerHTML on the public side (J1
  // pattern from Phase 2 messageParagraphs). Author trust is the
  // operational control while audience is the chair.
  introHeading             String
  introBody1               String   @db.Text
  introBody2               String   @db.Text
  introImageUrl            String
  introImagePublicId       String?
  // Stats — variable-length [{ value, label }]
  stats                    Json
  // Activities section
  activitiesOverline       String?
  activitiesHeading        String
  // Activities — variable-length [{ iconName, imageUrl, imagePublicId?, category, title, description }]
  // iconName resolved against a curated Lucide IconMap at render
  // time (same pattern as Phase 3 QuickAccessItem.iconName).
  activities               Json
  // Network section + 2 CTAs
  networkOverline          String?
  networkHeading           String
  networkBody              String   @db.Text
  networkPrimaryCtaLabel   String
  networkPrimaryCtaHref    String
  networkSecondaryCtaLabel String?
  networkSecondaryCtaHref  String?
  updatedAt                DateTime @updatedAt

  @@map("about_mecha_club")
}
